<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.frigate-bridge</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/Cellar/node@20/20.20.1/bin/node</string>
        <string>/Users/sn/frigate-bridge/bridge.mjs</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/sn/frigate-bridge</string>

    <key>StandardOutPath</key>
    <string>/Users/sn/frigate-bridge/bridge.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/sn/frigate-bridge/bridge.log</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
